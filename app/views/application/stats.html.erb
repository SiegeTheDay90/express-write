<main class="pt-2">
  <div class="d-flex justify-content-between col-lg-8 col-sm-10">
    <div>
      <span class="fw-bold">📝 Letters Generated:</span> <%= TempLetter.count %> <br>
      <span class="fw-bold">🔎 Resumes Evaluated:</span> <%= Request.where(ok: true, resource_type: "resume").count %> <br>
      <span class="fw-bold">🔄 AJAX Requests this week:</span> <%= requests_this_week.count %> <br>
      <span class="fw-bold">⌛ Avg Request Time this Week:</span> <%= (avg = Request.average_uptime).is_a?(Numeric) ? "#{avg.round(3)} seconds" : avg %> <br>
      <% if (a = days_since_last_error) > 4 %>
        <span class="fw-bold">⚠️ Days since a failed request:</span> <%= a %> 
      <% end %>
    </div>

    <div>
      Ruby on Rails 7 (Backend)<br>
      React 18 (Resume Tool)<br>
      Bootstrap 5 (Styling)<br>
      Google Firebase (Stat Tracking)<br>
    </div>

  </div>
  <hr>
  <div>
    <script>
      function chartTypeChange(e){
        const chartClass = e.target.dataset.category;
        const visibleChart = document.querySelector(`[data-category="${chartClass}-canvas"]:not(.d-none)`);
        const targetChart = document.getElementById(e.target.value);
        targetChart.classList.remove('d-none');
        visibleChart.classList.add('d-none');
      }
    </script>
    <div>
      <h6>Splash Page</h6>
      <label>Weekly
        <input class="me-3" type="radio" name="chartType" data-category="splash-hitChart" value="weeklyHitChart" onChange="chartTypeChange(event)" />
      </label>
      <label>Daily
        <input class="me-3" type="radio" name="chartType" data-category="splash-hitChart" value="dailyHitChart" onChange="chartTypeChange(event)" checked />
      </label>
    </div>
  </div>
  <div class="d-lg-flex col-sm-9 col-md-8 col-lg-6">
    <canvas id="dailyHitChart" data-category="splash-hitChart-canvas" class="hitChart"></canvas>
    <canvas id="weeklyHitChart" data-category="splash-hitChart-canvas" class="hitChart d-none"></canvas>
  </div>
  <div>
    <div>
      <h6>Job Boards</h6>
      <label>Weekly
        <input class="me-3" type="radio" name="jobBoard-chartType" data-category="jobBoard-hitChart" value="jobBoard-weeklyHitChart" onChange="chartTypeChange(event)" />
      </label>
      <label>Daily
        <input class="me-3" type="radio" name="jobBoard-chartType" data-category="jobBoard-hitChart" value="jobBoard-dailyHitChart" onChange="chartTypeChange(event)" checked />
      </label>
    </div>
  </div>
  <div class="d-lg-flex col-sm-9 col-md-8 col-lg-6">
    <canvas id="jobBoard-dailyHitChart" data-category="jobBoard-hitChart-canvas" class="hitChart"></canvas>
    <canvas id="jobBoard-weeklyHitChart" data-category="jobBoard-hitChart-canvas" class="hitChart d-none"></canvas>
  </div>

  <div>
    <div>
      <h6>Resume Builder</h6>
      <label>Weekly
        <input class="me-3" type="radio" name="resumeBuilder-chartType" data-category="resumeBuilder-hitChart" value="resumeBuilder-weeklyHitChart" onChange="chartTypeChange(event)" />
      </label>
      <label>Daily
        <input class="me-3" type="radio" name="resumeBuilder-chartType" data-category="resumeBuilder-hitChart" value="resumeBuilder-dailyHitChart" onChange="chartTypeChange(event)" checked />
      </label>
    </div>
  </div>
  <div class="d-lg-flex col-sm-9 col-md-8 col-lg-6">
    <canvas id="resumeBuilder-dailyHitChart" data-category="resumeBuilder-hitChart-canvas" class="hitChart"></canvas>
    <canvas id="resumeBuilder-weeklyHitChart" data-category="resumeBuilder-hitChart-canvas" class="hitChart d-none"></canvas>
  </div>


</main>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>



<script defer>
  const ctx = document.getElementById('dailyHitChart');
  const ctx2 = document.getElementById('weeklyHitChart');

  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: [
        <% @labels.each do |label| %>
            "<%= label %>",
        <% end %>
      ]
      ,
      datasets: [{
        label: 'Splash Page Loads',
        data: <%= @values %>,
        borderWidth: 3
      }]
    },
  });

  new Chart(ctx2, {
    type: 'line',
    data: {
      labels: [
        <% @weekly_labels.each do |label| %>
            "<%= label %>",
        <% end %>
      ]
      ,
      datasets: [{
        label: 'Weekly Page Loads',
        data: <%= @weekly_values %>,
        borderWidth: 3
      }]
    },
  });
</script>

<script defer>
  const ctx3 = document.getElementById('jobBoard-dailyHitChart');
  const ctx4 = document.getElementById('jobBoard-weeklyHitChart');

  new Chart(ctx3, {
    type: 'bar',
