            "<%= label %>",
        <% end %>
      ]
      ,
      datasets: [{
        label: 'Job Board Weekly Page Loads',
        data: <%= @job_board_weekly_values %>,
        borderWidth: 3
      }]
    },
  });
</script>

<script defer>
  const ctx5 = document.getElementById('resumeBuilder-dailyHitChart');
  const ctx6 = document.getElementById('resumeBuilder-weeklyHitChart');

  new Chart(ctx5, {
    type: 'bar',
    data: {
      labels: [
        <% @resume_builder_labels.each do |label| %>
            "<%= label %>",
        <% end %>
      ]
      ,
      datasets: [{
        label: 'Resume Builder Daily Page Loads',
        data: <%= @resume_builder_values %>,
        borderWidth: 3
      }]
    },
  });

  new Chart(ctx6, {
    type: 'line',
    data: {
      labels: [
        <% @resume_builder_weekly_labels.each do |label| %>
            "<%= label %>",
        <% end %>
      ]
      ,
      datasets: [{
        label: 'Resume Builder Weekly Page Loads',
        data: <%= @resume_builder_weekly_values %>,
        borderWidth: 3
      }]
    },
  });
</script>

