<!DOCTYPE html>
<html lang="en"l>
  <head>
    <title>ExpressWrite</title>
    <meta property="og:title" content="ExpressWrite - Cover Letters & Resumes" />
    <meta property="og:description" content="ExpressWrite is an AI project built by one developer. Use it for free!" />
    <meta property="og:url" content="https://www.expresswrite.ai" />
    <meta property="og:image" content="https://cl-helper-development.s3.amazonaws.com/writewise-preview.png" />
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <script src="https://kit.fontawesome.com/a65848e44c.js" crossorigin="anonymous"></script>

    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3577448772896761"
     crossorigin="anonymous"></script>
    
    
     
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-4bw+/aepP/YC94hEpVNVgiZdgIC5+VKNBQNGCHeKRQN+PtmoHDEXuppvnDJzQIu9" crossorigin="anonymous">
    <link rel="icon" href="https://cl-helper-development.s3.amazonaws.com/logo.png" type="image/png">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application" %>
    <%= javascript_importmap_tags %>
  </head>

  <body id="main">
    <header id="banner">
      <span style="height: 100%;">
        <a href=<%= root_url %> class="logo"><img id="logo-img" src="https://cl-helper-development.s3.amazonaws.com/logo_white.png" alt="Logo">ExpressWrite</a>
        <br>
        <a href="https://www.linkedin.com/in/clarence-smith-nyc/" rel="noopener noreferrer" class="link-light">Developed by Clarence Smith</a>
      </span>

    </header>

    <%= yield %>
    <%= render "layouts/footer" %>
    
  </body>
</html>
